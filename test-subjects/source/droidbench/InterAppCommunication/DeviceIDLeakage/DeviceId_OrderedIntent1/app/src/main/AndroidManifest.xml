<?xml version="1.0" encoding="utf-8" standalone="no"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" android:versionCode="1" android:versionName="1.0">
      
    
    
  <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
      
  <application android:allowBackup="true" android:label="@string/app_name">
            
    <activity android:exported="true" android:label="@string/app_name" android:name=".MainActivity">
                  
      <intent-filter>
                        
        <action android:name="android.intent.action.MAIN"/>
                        
        <category android:name="android.intent.category.LAUNCHER"/>
                    
      </intent-filter>
              
    </activity>
            
    <receiver android:name="Receiver2">
       			
      <intent-filter android:priority="2">
          				
        <action android:name="com.example.deviceid_orderedintent"/>
         
  			
      </intent-filter>
        		
    </receiver>
     		
    <receiver android:name="Receiver3">
       			
      <intent-filter android:priority="3">
          				
        <action android:name="com.example.deviceid_orderedintent"/>
         
  			
      </intent-filter>
        		
    </receiver>
            
    
  </application>
  
</manifest>

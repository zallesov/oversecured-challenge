<?xml version="1.0" encoding="utf-8" standalone="no"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" android:versionCode="1" android:versionName="1.0">

    

    <application android:allowBackup="true" android:label="@string/app_name">
        <activity android:exported="true" android:label="@string/app_name" android:name="edu.mit.icc_concat_action_string.OutFlowActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        
        <activity android:exported="true" android:label="@string/app_name" android:name="edu.mit.icc_concat_action_string.InFlowActivity">
            <intent-filter>
                <action android:name="edu.mit.icc_concat_action_string.ACTION"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        
        <activity android:exported="true" android:label="@string/app_name" android:name="edu.mit.icc_concat_action_string.IsolateActivity">
	  <intent-filter>
	    <action android:name="edu.mit.icc_concat_action_string.EDIT"/>
	    <category android:name="android.intent.category.DEFAULT"/>
	  </intent-filter>
        </activity>
    </application>

    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
</manifest>

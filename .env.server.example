# Copy to .env.server and fill in. Used by docker-compose.server.yml.
# `docker compose -f docker-compose.server.yml -p oversecured --env-file .env.server up -d`

# --- secrets ---
# REQUIRED. PocketBase superuser credentials — must be the same for the `pocketbase`
# service (seeds the superuser on first boot) and the `ui` service (backend authenticates
# as superuser). Generate a strong password; the PocketBase admin UI is published on 18090.
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=

# REQUIRED. Shared secret between the `ui` backend and the `worker`. The backend mints
# this into each job's Temporal activity header; the worker echoes it back in status
# callbacks; the backend validates inbound callbacks against it.
# Generate: openssl rand -hex 32
STATUS_CALLBACK_SECRET=

# OpenRouter key for the always-on AI triage step. Optional: without it the
# step is fail-soft and writes an empty sidecar. Model defaults to claude-haiku-4.5.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# --- build ---
# Android API level for the baked android.jar (github.com/Sable/android-platforms).
ANDROID_API=34
# Tag applied to locally built images (oversecured-ui, oversecured-worker).
IMAGE_TAG=latest

# --- published host ports (offset to 18xxx to avoid colliding with other host stacks) ---
UI_PORT=18030
TEMPORAL_UI_PORT=18080
# PocketBase admin UI + realtime API. Set to a port reachable from browsers if not behind a proxy.
POCKETBASE_PORT=18090

# --- client build ---
# Browser-reachable URL of the PocketBase service, baked into the client bundle.
# If behind a reverse proxy at a public domain, set to that URL instead.
VITE_POCKETBASE_URL=http://localhost:18090

# CORS origin the Temporal UI accepts. Set to the externally reachable UI origin if proxied.
TEMPORAL_UI_CORS_ORIGINS=http://localhost:18030

# --- optional backend tuning (defaults exist in code) ---
# How often the backend reconciles stale run records (ms). Default: 60000.
# RUN_RECONCILE_INTERVAL_MS=60000
# Age at which an in-progress run is considered stale (ms). Default: 600000.
# RUN_STALE_MS=600000

# --- REMOVED ---
# UI_DB_USER, UI_DB_PASSWORD, UI_DB_NAME — removed; the UI DB is now PocketBase (see above).
# STATUS_SYNC_INTERVAL_MS — removed; replaced by PocketBase realtime subscriptions.
# JWT_SECRET — removed; auth is now handled by PocketBase, not backend-signed JWTs.
